{
  "kind": "collectionType",
  "collectionName": "team_members",
  "info": {
    "displayName": "TeamMember",
    "description": "团队成员",
    "singularName": "team-member",
    "pluralName": "team-members"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "teamGroup": {
      "type": "enumeration",
      "enum": ["china-hk", "hk", "usa", "sea", "europe"],
      "required": true
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "shortDescription": {
      "type": "text"
    },
    "fullDescription": {
      "type": "richtext"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    }
  }
}
