{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "displayName": "Service",
    "description": "服务内容（固定6类）",
    "singularName": "service",
    "pluralName": "services"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "highlight": {
      "type": "text"
    },
    "detailItems": {
      "type": "component",
      "repeatable": true,
      "component": "service.detail-items"
    },
    "advantagesTitle": {
      "type": "string"
    },
    "advantagesSubtitle": {
      "type": "string"
    },
    "advantages": {
      "type": "component",
      "repeatable": true,
      "component": "service.advantage"
    },
    "metaTitle": {
      "type": "string"
    },
    "metaDescription": {
      "type": "text"
    }
  }
}
